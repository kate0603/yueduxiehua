.container {
  padding: 20rpx;
  min-height: 100vh;
  background: linear-gradient(135deg, #FFE082 0%, #FFD54F 50%, #FFCA28 100%);
}

.header {
  text-align: center;
  padding: 60rpx 0 30rpx;
  position: relative;
}

.title-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.title {
  font-size: 64rpx;
  font-weight: bold;
  color: #ffffff;
  text-shadow: 4rpx 4rpx 8rpx rgba(0, 0, 0, 0.2);
  animation: titleBounce 2s ease-in-out infinite;
}

.star {
  font-size: 48rpx;
  animation: starTwinkle 1.5s ease-in-out infinite;
}

.star-1 {
  animation-delay: 0s;
}

.star-2 {
  animation-delay: 0.5s;
}

.subtitle {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.95);
  margin-top: 20rpx;
  font-weight: 500;
}

.current-grade {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 15rpx;
}

.change-grade {
  font-size: 24rpx;
  color: #ffffff;
  margin-top: 10rpx;
  padding: 10rpx 20rpx;
  display: inline-block;
}

.sparkles {
  font-size: 36rpx;
  margin-top: 15rpx;
  animation: sparkleFloat 2s ease-in-out infinite;
}

.tip-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 35rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.15);
  position: relative;
}

.tip-card::before {
  content: '🌟';
  position: absolute;
  top: -15rpx;
  right: -15rpx;
  font-size: 80rpx;
  opacity: 0.2;
}

.tip-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.tip-icon {
  font-size: 36rpx;
}

.tip-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #FF9800;
}

.tip-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.7;
  margin-bottom: 15rpx;
  word-break: break-all;
  text-align: justify;
}

.tip-footer {
  font-size: 26rpx;
  color: #4CAF50;
  text-align: right;
  font-weight: 600;
}

.module-list {
  display: flex;
  flex-direction: column;
  gap: 35rpx;
}

.module-card {
  border-radius: 28rpx;
  padding: 40rpx;
  box-shadow: 0 15rpx 40rpx rgba(0, 0, 0, 0.2);
  display: flex;
  align-items: center;
  transition: transform 0.3s, box-shadow 0.3s;
  position: relative;
  overflow: hidden;
}

.module-card:active {
  transform: scale(0.96);
}

.module-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.module-icon-wrapper {
  position: relative;
  margin-right: 30rpx;
}

.module-icon {
  font-size: 90rpx;
  animation: iconFloat 3s ease-in-out infinite;
}

.module-badge {
  position: absolute;
  top: -10rpx;
  right: -20rpx;
  background: #FF5722;
  color: #ffffff;
  font-size: 20rpx;
  padding: 5rpx 15rpx;
  border-radius: 20rpx;
  font-weight: bold;
}

.module-info {
  flex: 1;
}

.module-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 10rpx;
}

.module-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.module-arrow {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: bold;
}

.fun-fact-card {
  background: linear-gradient(135deg, #ffffff, #FFF9C4);
  border-radius: 24rpx;
  padding: 35rpx;
  margin-top: 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
  display: flex;
  gap: 25rpx;
  position: relative;
}

.fun-fact-card::before {
  content: '💡';
  position: absolute;
  top: -30rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 60rpx;
  animation: floatUpDown 2s ease-in-out infinite;
}

.fun-icon {
  font-size: 60rpx;
  animation: diceRoll 3s ease-in-out infinite;
}

.fun-content {
  flex: 1;
}

.fun-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #7B1FA2;
  margin-bottom: 15rpx;
}

.fun-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.7;
}

.progress-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 35rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 50rpx;
}

.progress-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  text-align: center;
}

.progress-bars {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.progress-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.progress-label {
  width: 140rpx;
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.progress-bar {
  flex: 1;
  height: 30rpx;
  background: #f0f0f0;
  border-radius: 30rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4CAF50, #8BC34A);
  border-radius: 30rpx;
  transition: width 1s ease-out;
  position: relative;
}

.progress-fill::after {
  content: '';
  position: absolute;
  right: 10rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 12rpx;
  height: 12rpx;
  background: #ffffff;
  border-radius: 50%;
}

.progress-fill.writing {
  background: linear-gradient(90deg, #2196F3, #64B5F6);
}

.progress-percent {
  width: 80rpx;
  font-size: 26rpx;
  color: #4CAF50;
  font-weight: bold;
  text-align: right;
}

@keyframes titleBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

@keyframes starTwinkle {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.6; transform: scale(1.2); }
}

@keyframes sparkleFloat {
  0%, 100% { transform: translateY(0); opacity: 1; }
  50% { transform: translateY(-15rpx); opacity: 0.7; }
}

@keyframes iconFloat {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  25% { transform: translateY(-5rpx) rotate(3deg); }
  75% { transform: translateY(5rpx) rotate(-3deg); }
}

@keyframes floatUpDown {
  0%, 100% { transform: translateX(-50%) translateY(0); }
  50% { transform: translateX(-50%) translateY(-10rpx); }
}

@keyframes diceRoll {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(10deg); }
  75% { transform: rotate(-10deg); }
}

.animate-float {
  animation: floatUpDownCard 3s ease-in-out infinite;
}

@keyframes floatUpDownCard {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.animate-bounce-in {
  animation: bounceIn 0.6s ease-out;
}

.animate-bounce-in-delay {
  animation: bounceIn 0.6s ease-out 0.2s;
  animation-fill-mode: both;
}

@keyframes bounceIn {
  0% { transform: scale(0.8); opacity: 0; }
  50% { transform: scale(1.05); }
  100% { transform: scale(1); opacity: 1; }
}
