<view class="container">
  <view class="header">
    <view class="back-btn" bindtap="goBack">← 返回</view>
    <view class="header-title">
      <text class="title-emoji">📚</text>
      <text class="title-text">选择主题</text>
    </view>
    <view class="header-placeholder"></view>
  </view>

  <view class="section">
    <view class="section-title">🎯 选择主题分类</view>
    
    <scroll-view class="sub-category-scroll" scroll-x>
      <view class="sub-category-list">
        <view class="sub-category-item {{selectedSubCategory === 'all' ? 'selected' : ''}}" 
              bindtap="selectSubCategory" data-subcategory="all">
          <view class="sub-category-icon">📋</view>
          <view class="sub-category-name">全部</view>
        </view>
        <view class="sub-category-item {{selectedSubCategory === item.id ? 'selected' : ''}}" 
              wx:for="{{subCategories}}" wx:key="id" 
              bindtap="selectSubCategory" data-subcategory="{{item.id}}">
          <view class="sub-category-icon">{{item.icon}}</view>
          <view class="sub-category-name">{{item.name}}</view>
        </view>
      </view>
    </scroll-view>
    
    <scroll-view class="topic-scroll" scroll-y>
      <view class="topic-list">
        <view class="topic-card {{selectedTopic === item.id ? 'selected' : ''}}" 
              wx:for="{{pendingTopics}}" wx:key="id" 
              bindtap="selectTopic" data-id="{{item.id}}">
          <view class="topic-info">
            <view class="topic-emoji">{{item.emoji}}</view>
            <view class="topic-title">{{item.title}}</view>
            <view class="topic-meta">
              <text class="topic-difficulty">{{item.difficultyText}}</text>
              <text class="topic-grade">第{{item.grade}}年级</text>
            </view>
          </view>
          <view class="topic-check" wx:if="{{selectedTopic === item.id}}">✓</view>
        </view>
        
        <view class="completed-label" wx:if="{{doneTopics.length > 0}}">已完成</view>
        
        <view class="topic-card completed {{selectedTopic === item.id ? 'selected' : ''}}" 
              wx:for="{{doneTopics}}" wx:key="id" 
              bindtap="selectTopic" data-id="{{item.id}}">
          <view class="topic-info">
            <view class="topic-emoji">{{item.emoji}}</view>
            <view class="topic-title">{{item.title}}</view>
            <view class="topic-meta">
              <text class="topic-difficulty">{{item.difficultyText}}</text>
              <text class="topic-grade">第{{item.grade}}年级</text>
            </view>
            <view class="completed-tag">✓ 已完成</view>
          </view>
          <view class="topic-check" wx:if="{{selectedTopic === item.id}}">✓</view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="bottom-bar">
    <view class="bottom-btn {{selectedTopic ? 'active' : ''}}" bindtap="startPractice">
      <text class="btn-text">{{selectedTopic ? '✍️ 开始练习' : '请选择一个主题'}}</text>
    </view>
  </view>
</view>