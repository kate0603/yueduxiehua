.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
  padding-bottom: 180rpx;
  box-sizing: border-box;
  position: relative;
  overflow-x: hidden;
}

.container::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle at 20% 30%, rgba(255,255,255,0.1) 0%, transparent 50%);
  pointer-events: none;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 60rpx 30rpx 30rpx;
}

.back-btn {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: bold;
}

.header-title {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.title-emoji {
  font-size: 48rpx;
}

.title-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
}

.header-placeholder {
  width: 100rpx;
}

.section {
  padding: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 20rpx;
}

.sub-category-scroll {
  white-space: nowrap;
  margin-bottom: 25rpx;
}

.sub-category-list {
  display: inline-flex;
  gap: 15rpx;
  padding: 10rpx 0;
}

.sub-category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 28rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  backdrop-filter: blur(10px);
  min-width: 100rpx;
  transition: all 0.3s;
}

.sub-category-item.selected {
  background: rgba(255, 255, 255, 0.3);
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
}

.sub-category-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.sub-category-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #ffffff;
}

.topic-scroll {
  height: calc(100vh - 420rpx);
}

.topic-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.topic-card {
  display: flex;
  align-items: center;
  padding: 28rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  box-shadow: 0 6rpx 22rpx rgba(0, 0, 0, 0.06);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.topic-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: linear-gradient(180deg, #4CAF50, #66BB6A);
  opacity: 0;
  transition: opacity 0.3s;
}

.topic-card.selected {
  background: rgba(232, 245, 233, 0.95);
  box-shadow: 0 10rpx 30rpx rgba(76, 175, 80, 0.15);
}

.topic-card.selected::before {
  opacity: 1;
}

.topic-card.completed {
  background: rgba(248, 249, 250, 0.95);
}

.topic-card.completed:active {
  transform: scale(0.98);
}

.topic-card.completed.selected {
  background: rgba(232, 245, 233, 0.95);
  opacity: 1;
}

.image-container {
  position: relative;
  width: 140rpx;
  height: 100rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  overflow: hidden;
}

.topic-image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.image-error {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(200, 200, 200, 0.8);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

.error-icon {
  font-size: 36rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.error-text {
  font-size: 20rpx;
  color: #666;
  margin-top: 4rpx;
}

.topic-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.topic-emoji {
  font-size: 44rpx;
  margin-bottom: 6rpx;
}

.topic-title {
  font-size: 32rpx;
  color: #2D3748;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.topic-meta {
  display: flex;
  gap: 15rpx;
}

.topic-difficulty {
  font-size: 22rpx;
  color: #FF9800;
}

.topic-grade {
  font-size: 22rpx;
  color: #667eea;
}

.completed-tag {
  font-size: 22rpx;
  color: #4CAF50;
  margin-top: 4rpx;
}

.topic-check {
  width: 44rpx;
  height: 44rpx;
  background: #4CAF50;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 28rpx;
  flex-shrink: 0;
}

.completed-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  text-align: center;
  margin: 30rpx 0 20rpx 0;
  padding-bottom: 10rpx;
  border-bottom: 2rpx dashed rgba(255, 255, 255, 0.2);
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 30rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -8rpx 30rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
  backdrop-filter: blur(20px);
}

.bottom-btn {
  padding: 28rpx;
  background: linear-gradient(135deg, #E8E8E8, #F5F5F5);
  border-radius: 50rpx;
  text-align: center;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.bottom-btn.active {
  background: linear-gradient(135deg, #667eea, #764ba2);
  box-shadow: 0 12rpx 35rpx rgba(102, 126, 234, 0.4);
}

.btn-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #BDBDBD;
}

.bottom-btn.active .btn-text {
  color: #ffffff;
}