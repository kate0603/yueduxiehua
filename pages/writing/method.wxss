.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
  padding-bottom: 40rpx;
  box-sizing: border-box;
  position: relative;
  overflow-x: hidden;
}

.container::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle at 20% 30%, rgba(255,255,255,0.1) 0%, transparent 50%);
  pointer-events: none;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 60rpx 30rpx 30rpx;
}

.back-btn {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: bold;
}

.header-title {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.title-emoji {
  font-size: 48rpx;
}

.title-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
}

.header-placeholder {
  width: 100rpx;
}

.section {
  padding: 30rpx;
}

.section-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  text-align: center;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.15);
}

.section-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  text-align: center;
  margin-bottom: 40rpx;
}

.method-list {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.method-card {
  display: flex;
  align-items: center;
  padding: 40rpx;
  border-radius: 28rpx;
  box-shadow: 0 12rpx 35rpx rgba(0, 0, 0, 0.2);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.method-card:active {
  transform: scale(0.98);
}

.method-icon {
  font-size: 64rpx;
  margin-right: 28rpx;
}

.method-info {
  flex: 1;
}

.method-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 10rpx;
}

.method-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.method-arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.8);
}