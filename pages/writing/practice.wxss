.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #C8E6C9 50%, #A5D6A7 100%);
  padding-bottom: 280rpx;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 60rpx 30rpx 20rpx;
}

.back-btn {
  font-size: 32rpx;
  color: #2E7D32;
  font-weight: bold;
}

.header-title {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.title-emoji {
  font-size: 44rpx;
}

.title-text {
  font-size: 38rpx;
  font-weight: bold;
  color: #1B5E20;
}

.header-placeholder {
  width: 100rpx;
}

.steps-bar {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 30rpx;
  background: rgba(255, 255, 255, 0.8);
  margin: 0 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.step-num {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #E0E0E0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #9E9E9E;
  transition: all 0.3s;
}

.step-num.active {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: #ffffff;
}

.step-name {
  font-size: 24rpx;
  color: #9E9E9E;
}

.step-name.active {
  color: #2E7D32;
  font-weight: 600;
}

.image-section {
  padding: 30rpx;
}

.image-section .image-frame {
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
  position: relative;
}

.image-section .topic-image {
  width: 100%;
  max-height: 500rpx;
  object-fit: contain;
}

.image-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
}

.overlay-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.loading-spinner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 15rpx;
}

.spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #E0E0E0;
  border-top-color: #4CAF50;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #666;
}

.error-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 15rpx;
}

.error-icon {
  font-size: 64rpx;
}

.error-text {
  font-size: 28rpx;
  color: #999;
}

.refresh-btn {
  padding: 15rpx 30rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #ffffff;
  border-radius: 50rpx;
  font-size: 28rpx;
  box-shadow: 0 4rpx 15rpx rgba(102, 126, 234, 0.4);
}

.refresh-btn:active {
  transform: scale(0.98);
}

.image-title {
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #1B5E20;
  margin-top: 15rpx;
}

.options-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.option-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #F5F5F5;
  padding: 25rpx;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.option-item.selected {
  background: #E8F5E9;
  border-color: #4CAF50;
}

.option-letter {
  width: 50rpx;
  height: 50rpx;
  background: #E0E0E0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #666;
}

.option-item.selected .option-letter {
  background: #4CAF50;
  color: #ffffff;
}

.option-content {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.option-item.selected .option-content {
  color: #2E7D32;
  font-weight: 600;
}

.step-content {
  padding: 30rpx;
}

.submit-btn {
  margin-top: 30rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
  color: #ffffff;
  border-radius: 50rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: bold;
  box-shadow: 0 10rpx 30rpx rgba(76, 175, 80, 0.4);
  transition: all 0.3s;
}

.submit-btn:active {
  transform: scale(0.98);
  box-shadow: 0 6rpx 20rpx rgba(76, 175, 80, 0.3);
}

.result-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-top: 25rpx;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.1);
  text-align: center;
}

.result-emoji {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.result-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 30rpx;
}

.result-btn {
  padding: 28rpx;
  background: linear-gradient(135deg, #1976D2 0%, #42A5F5 100%);
  color: #ffffff;
  border-radius: 50rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: bold;
  box-shadow: 0 10rpx 30rpx rgba(25, 118, 210, 0.4);
  transition: all 0.3s;
}

.result-btn:active {
  transform: scale(0.98);
  box-shadow: 0 6rpx 20rpx rgba(25, 118, 210, 0.3);
}

.content-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 35rpx;
  margin-bottom: 25rpx;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.1);
}

.card-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1B5E20;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.image-frame {
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 25rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
}

.topic-image {
  width: 100%;
  max-height: 500rpx;
  object-fit: contain;
}

.image-hint {
  display: flex;
  align-items: center;
  gap: 15rpx;
  font-size: 28rpx;
  color: #66BB6A;
  background: #E8F5E9;
  padding: 20rpx;
  border-radius: 16rpx;
}

.hint-emoji {
  font-size: 36rpx;
}

.method-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 35rpx;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.1);
}

.method-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2E7D32;
  margin-bottom: 25rpx;
}

.method-tips {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.tip-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #E8F5E9;
  padding: 15rpx 25rpx;
  border-radius: 30rpx;
}

.tip-num {
  width: 36rpx;
  height: 36rpx;
  background: #4CAF50;
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
}

.tip-text {
  font-size: 26rpx;
  color: #2E7D32;
}

.fill-blank-box {
  background: #E3F2FD;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 25rpx;
}

.fill-blank-sentence {
  font-size: 34rpx;
  color: #1565C0;
  line-height: 1.8;
  font-weight: 500;
}

.option-item.correct {
  background: #E8F5E9 !important;
  border-color: #4CAF50 !important;
  animation: pulse 0.5s ease-in-out;
}

@keyframes pulse {
  0% { transform: scale(1); }
  50% { transform: scale(1.03); }
  100% { transform: scale(1); }
}

.option-icon {
  margin-left: auto;
  width: 44rpx;
  height: 44rpx;
  background: #4CAF50;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: bold;
}

.answer-tip {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 25rpx;
  padding: 25rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #FFF8E1 0%, #FFECB3 100%);
  animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.answer-tip-icon {
  font-size: 44rpx;
}

.answer-tip-text {
  font-size: 32rpx;
  color: #5D4037;
  font-weight: 500;
}

.correct-answer {
  color: #4CAF50;
  font-weight: bold;
  font-size: 36rpx;
}

.next-question-btn {
  margin-top: 25rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, #66BB6A 0%, #4CAF50 100%);
  color: #ffffff;
  border-radius: 50rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 25rpx rgba(76, 175, 80, 0.35);
  transition: all 0.3s;
}

.next-question-btn:active {
  transform: scale(0.98);
  box-shadow: 0 5rpx 15rpx rgba(76, 175, 80, 0.3);
}

.question-list {
  display: flex;
  flex-direction: column;
  gap: 25rpx;
}

.question-item {
  background: #F1F8E9;
  padding: 25rpx;
  border-radius: 16rpx;
  border-left: 6rpx solid #4CAF50;
}

.question-num {
  width: 40rpx;
  height: 40rpx;
  background: #C8E6C9;
  color: #2E7D32;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: bold;
  margin-bottom: 15rpx;
}

.question-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 15rpx;
}

.answer-box {
  background: #E8F5E9;
  padding: 20rpx;
  border-radius: 12rpx;
}

.answer-label {
  font-size: 24rpx;
  color: #81C784;
  margin-bottom: 10rpx;
}

.answer-text {
  font-size: 28rpx;
  color: #2E7D32;
  font-weight: 600;
}

.toggle-btn {
  text-align: center;
  padding: 20rpx;
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: #ffffff;
  border-radius: 50rpx;
  font-size: 30rpx;
  margin-top: 25rpx;
  box-shadow: 0 6rpx 20rpx rgba(76, 175, 80, 0.3);
}

.sentence-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.sentence-item {
  display: flex;
  align-items: flex-start;
  gap: 15rpx;
  background: #F3E5F5;
  padding: 20rpx;
  border-radius: 16rpx;
  border-left: 6rpx solid #9C27B0;
}

.sentence-num {
  width: 40rpx;
  height: 40rpx;
  background: #CE93D8;
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.sentence-text {
  font-size: 28rpx;
  color: #4A148C;
  line-height: 1.6;
}

.sentence-hint {
  display: flex;
  align-items: center;
  gap: 15rpx;
  font-size: 28rpx;
  color: #9C27B0;
  background: #FCE4EC;
  padding: 20rpx;
  border-radius: 16rpx;
  margin-top: 25rpx;
}

.sample-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
  white-space: pre-wrap;
}

.action-bar {
  position: fixed;
  bottom: 120rpx;
  left: 30rpx;
  right: 30rpx;
  display: flex;
  gap: 25rpx;
}

.btn-prev, .btn-next, .btn-finish {
  flex: 1;
  padding: 25rpx;
  border-radius: 50rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.2);
}

.btn-prev {
  background: #E0E0E0;
  color: #757575;
}

.btn-prev.disabled {
  opacity: 0.5;
}

.btn-next {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: #ffffff;
}

.btn-finish {
  background: linear-gradient(135deg, #FFD54F, #FFA726);
  color: #ffffff;
}

.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: #ffffff;
  padding: 20rpx 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.nav-item {
  flex: 1;
  text-align: center;
  font-size: 30rpx;
  color: #9E9E9E;
  padding: 15rpx;
}

.nav-item.active {
  color: #4CAF50;
  font-weight: bold;
}
