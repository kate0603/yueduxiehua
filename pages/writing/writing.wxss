.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E3F2FD 0%, #BBDEFB 50%, #90CAF9 100%);
  padding-bottom: 120rpx;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 60rpx 30rpx 30rpx;
}

.back-btn {
  font-size: 32rpx;
  color: #1976D2;
  font-weight: bold;
}

.header-title {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.title-emoji {
  font-size: 48rpx;
}

.title-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #1565C0;
}

.header-placeholder {
  width: 100rpx;
}

.steps-bar {
  display: flex;
  justify-content: center;
  gap: 60rpx;
  padding: 20rpx 30rpx;
  margin: 0 30rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.step-num {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #E0E0E0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #9E9E9E;
  transition: all 0.3s;
}

.step-num.active {
  background: linear-gradient(135deg, #1976D2, #42A5F5);
  color: #ffffff;
}

.step-name {
  font-size: 24rpx;
  color: #9E9E9E;
}

.step-name.active {
  color: #1976D2;
  font-weight: 600;
}

.section {
  padding: 30rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1565C0;
  text-align: center;
  margin-bottom: 15rpx;
}

.section-desc {
  font-size: 28rpx;
  color: #64B5F6;
  text-align: center;
  margin-bottom: 40rpx;
}

.method-list {
  display: flex;
  flex-direction: column;
  gap: 25rpx;
}

.method-card {
  display: flex;
  align-items: center;
  padding: 35rpx;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.15);
  transition: all 0.3s;
}

.method-card.selected {
  border: 4rpx solid #FFD54F;
}

.method-card:active {
  transform: scale(0.98);
}

.method-icon {
  font-size: 64rpx;
  margin-right: 25rpx;
}

.method-info {
  flex: 1;
}

.method-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #37474F;
  margin-bottom: 8rpx;
}

.method-card.selected .method-name {
  color: #ffffff;
}

.method-desc {
  font-size: 26rpx;
  color: #78909C;
}

.method-card.selected .method-desc {
  color: rgba(255, 255, 255, 0.9);
}

.method-check {
  font-size: 40rpx;
  color: #4CAF50;
}

.topic-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.topic-card {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s;
  position: relative;
}

.topic-card.selected {
  border: 4rpx solid #4CAF50;
  background: #E8F5E9;
}

.topic-card:active {
  transform: scale(0.99);
}

.topic-card.completed {
  opacity: 0.7;
  background: #F5F5F5;
}

.completed-label {
  font-size: 26rpx;
  color: #9E9E9E;
  text-align: center;
  margin: 30rpx 0 20rpx 0;
  padding-bottom: 10rpx;
  border-bottom: 2rpx dashed #E0E0E0;
}

.completed-tag {
  font-size: 22rpx;
  color: #4CAF50;
  margin-top: 4rpx;
}

.topic-emoji {
  font-size: 56rpx;
  margin-right: 25rpx;
}

.topic-info {
  flex: 1;
}

.topic-name {
  font-size: 34rpx;
  color: #37474F;
  font-weight: 600;
}

.topic-check {
  width: 48rpx;
  height: 48rpx;
  background: #4CAF50;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 32rpx;
}

.next-btn {
  margin-top: 40rpx;
  padding: 30rpx;
  background: linear-gradient(135deg, #1976D2, #42A5F5);
  color: #ffffff;
  border-radius: 50rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 25rpx rgba(25, 118, 210, 0.3);
}

.next-btn:active {
  transform: scale(0.98);
}