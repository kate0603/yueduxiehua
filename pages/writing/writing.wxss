.page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 60rpx 32rpx 32rpx;
}

.back-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 50%;
}

.back-icon {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: bold;
}

.title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.title-icon {
  font-size: 44rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
}

.header-placeholder {
  width: 72rpx;
}

.content {
  padding: 32rpx;
}

.desc-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  text-align: center;
  margin-bottom: 32rpx;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.card-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 32rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.12);
  transition: all 0.3s;
}

.card-item:active {
  transform: scale(0.98);
}

.card-left {
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.icon-box {
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #F0F4FF, #E0E8FF);
  border-radius: 20rpx;
  font-size: 48rpx;
}

.info {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.name {
  font-size: 34rpx;
  font-weight: 600;
  color: #2D3748;
}

.hint {
  font-size: 26rpx;
  color: #A0AEC0;
}

.card-right {
  display: flex;
  align-items: center;
}

.arrow {
  font-size: 36rpx;
  color: #667eea;
}

.lock {
  display: flex;
  flex-direction: column;
  align-items: center;
  opacity: 0.5;
}

.lock-icon {
  font-size: 28rpx;
}

.lock-text {
  font-size: 20rpx;
  color: #9E9E9E;
}