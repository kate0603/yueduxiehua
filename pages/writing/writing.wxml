<view class="page">
  <view class="header">
    <view class="back-btn" bindtap="goBack">
      <text class="back-icon">←</text>
    </view>
    <view class="title-wrap">
      <text class="title-icon">✍️</text>
      <text class="title">看图写话</text>
    </view>
    <view class="header-placeholder"></view>
  </view>

  <view class="content">
    <view class="desc-text">选择题型开始练习</view>
    
    <view class="card-list">
      <view 
        class="card-item" 
        wx:for="{{categories}}" 
        wx:key="id"
        bindtap="handleCategoryTap"
        data-category="{{item.id}}"
      >
        <view class="card-left">
          <view class="icon-box">{{item.icon}}</view>
          <view class="info">
            <text class="name">{{item.name}}</text>
            <text class="hint">{{item.suitable}}</text>
          </view>
        </view>
        <view class="card-right">
          <view class="arrow" wx:if="{{item.id === 'single'}}">→</view>
          <view class="lock" wx:else>
            <text class="lock-icon">🔒</text>
            <text class="lock-text">开发中</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>