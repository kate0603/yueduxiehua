.container {
  padding: 20rpx;
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 50%, #90CAF9 100%);
  min-height: 100vh;
}

.quick-nav {
  display: flex;
  justify-content: space-around;
  background: linear-gradient(135deg, #4CAF50, #8BC34A);
  border-radius: 20rpx;
  padding: 15rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 25rpx rgba(76, 175, 80, 0.3);
}

.quick-nav .nav-item {
  padding: 15rpx 25rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  transition: all 0.3s;
}

.quick-nav .nav-item.active {
  background: #ffffff;
  color: #4CAF50;
  font-weight: bold;
}

.tabs-container {
  display: flex;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  padding: 10rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 25rpx;
  border-radius: 20rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background: linear-gradient(135deg, #4CAF50, #8BC34A);
}

.tab-emoji {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.tab-name {
  font-size: 28rpx;
  color: #666;
  font-weight: bold;
}

.tab-item.active .tab-name {
  color: #ffffff;
}

.content-area {
  min-height: 60vh;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1565C0;
  padding-left: 10rpx;
  margin-bottom: 25rpx;
}

.method-list {
  display: flex;
  flex-direction: column;
  gap: 25rpx;
}

.method-card {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.3s;
}

.method-card:active {
  transform: scale(0.98);
}

.method-icon {
  font-size: 72rpx;
  margin-right: 25rpx;
}

.method-info {
  flex: 1;
}

.method-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1565C0;
  margin-bottom: 12rpx;
}

.method-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.method-arrow {
  font-size: 40rpx;
  color: #4CAF50;
  font-weight: bold;
}

.category-header {
  margin-bottom: 20rpx;
}

.category-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1565C0;
  padding-left: 10rpx;
}

.category-bar {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 20rpx;
  margin-bottom: 35rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
  white-space: nowrap;
}

.category-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 35rpx;
  margin: 0 10rpx;
  border-radius: 20rpx;
  background: #f5f5f5;
  transition: all 0.3s;
}

.category-item.active {
  background: linear-gradient(135deg, #4CAF50, #8BC34A);
  box-shadow: 0 4rpx 15rpx rgba(76, 175, 80, 0.3);
}

.category-emoji {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.category-name {
  font-size: 28rpx;
  color: #666;
}

.category-item.active .category-name {
  color: #ffffff;
}

.article-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.article-card {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.1);
  position: relative;
  transition: transform 0.3s;
}

.article-card:active {
  transform: scale(0.98);
}

.article-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  background: linear-gradient(135deg, #FF5722, #FF7043);
  color: #ffffff;
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-weight: bold;
  z-index: 1;
}

.article-content {
  padding: 30rpx;
}

.article-header {
  display: flex;
  align-items: center;
  margin-bottom: 25rpx;
}

.article-icon {
  font-size: 80rpx;
  margin-right: 25rpx;
  animation: iconFloat 3s ease-in-out infinite;
}

.article-info {
  flex: 1;
}

.article-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1565C0;
  margin-bottom: 15rpx;
}

.article-meta {
  display: flex;
  gap: 20rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  border-radius: 15rpx;
}

.meta-item.difficulty {
  background: #FFF3E0;
}

.meta-item.grade {
  background: #E3F2FD;
}

.meta-icon {
  font-size: 24rpx;
}

.meta-item text:last-child {
  font-size: 24rpx;
  color: #666;
}

.article-preview {
  font-size: 28rpx;
  color: #555;
  line-height: 1.7;
  margin-bottom: 25rpx;
  padding-left: 10rpx;
  border-left: 5rpx solid #4CAF50;
}

.article-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 2rpx dashed #E0E0E0;
}

.footer-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 26rpx;
  color: #666;
}

.footer-icon {
  font-size: 28rpx;
}

.footer-arrow {
  font-size: 28rpx;
  color: #4CAF50;
  font-weight: bold;
}

.empty-state {
  text-align: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 140rpx;
  margin-bottom: 30rpx;
  animation: iconFloat 3s ease-in-out infinite;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 15rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}

.article-card.completed {
  opacity: 0.75;
  background: linear-gradient(135deg, #F1F8E9, #DCEDC8);
}

.article-card.completed .article-title {
  color: #558B2F;
}

.meta-item.completed-tag {
  background: #C8E6C9;
  color: #2E7D32;
  font-weight: bold;
  font-size: 24rpx;
}

.article-card.completed .footer-arrow {
  color: #66BB6A;
}

@keyframes iconFloat {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  25% { transform: translateY(-5rpx) rotate(3deg); }
  75% { transform: translateY(5rpx) rotate(-3deg); }
}