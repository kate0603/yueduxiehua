.container {
  padding: 20rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #FFE0B2 0%, #FFCC80 30%, #FFB74D 60%, #FFA726 100%);
  position: relative;
  overflow: hidden;
}

.container::before {
  content: '';
  position: absolute;
  top: 100rpx;
  left: 50rpx;
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  animation: floatCloud 8s ease-in-out infinite;
}

.container::after {
  content: '';
  position: absolute;
  top: 200rpx;
  right: 80rpx;
  width: 60rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.4);
  border-radius: 50%;
  animation: floatCloud 10s ease-in-out infinite 2s;
}

@keyframes floatCloud {
  0%, 100% { transform: translateY(0) translateX(0); }
  25% { transform: translateY(-20rpx) translateX(30rpx); }
  50% { transform: translateY(-10rpx) translateX(-20rpx); }
  75% { transform: translateY(-30rpx) translateX(10rpx); }
}

.header {
  text-align: center;
  padding: 80rpx 0 50rpx;
  position: relative;
}

.title-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 25rpx;
}

.title {
  font-size: 72rpx;
  font-weight: bold;
  color: #E65100;
  text-shadow: 4rpx 4rpx 8rpx rgba(230, 81, 0, 0.3);
  animation: titleBounce 2s ease-in-out infinite;
  background: linear-gradient(135deg, #E65100, #FF8F00);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.star {
  font-size: 56rpx;
  animation: starTwinkle 1.5s ease-in-out infinite;
}

.star-1 {
  animation-delay: 0s;
}

.star-2 {
  animation-delay: 0.5s;
}

.subtitle {
  font-size: 34rpx;
  color: #BF360C;
  margin-top: 25rpx;
  font-weight: 600;
  background: rgba(255, 255, 255, 0.8);
  padding: 15rpx 40rpx;
  border-radius: 50rpx;
  display: inline-block;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
}

.sparkles {
  font-size: 40rpx;
  margin-top: 20rpx;
  animation: sparkleFloat 2s ease-in-out infinite;
}

.mode-section {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 32rpx;
  padding: 50rpx 40rpx;
  margin-bottom: 35rpx;
  box-shadow: 0 20rpx 50rpx rgba(230, 81, 0, 0.25);
  position: relative;
}

.mode-section::before {
  content: '🌟';
  position: absolute;
  top: -20rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 48rpx;
  animation: starPop 1s ease-in-out infinite;
}

@keyframes starPop {
  0%, 100% { transform: translateX(-50%) scale(1); }
  50% { transform: translateX(-50%) scale(1.3); }
}

.mode-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #E65100;
  margin-bottom: 40rpx;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 15rpx;
}

.mode-title::before,
.mode-title::after {
  content: '🌈';
  font-size: 32rpx;
}

.mode-options {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
}

.mode-item {
  display: flex;
  align-items: center;
  padding: 35rpx 40rpx;
  border-radius: 24rpx;
  transition: all 0.3s;
  border: 4rpx solid transparent;
  width: 100%;
  position: relative;
  overflow: hidden;
}

.mode-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  opacity: 0;
  transition: opacity 0.3s;
}

.mode-item.reading {
  background: linear-gradient(135deg, #FFE082 0%, #FFD54F 50%, #FFCA28 100%);
  box-shadow: 0 8rpx 25rpx rgba(255, 193, 7, 0.4);
}

.mode-item.reading::before {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.3) 0%, transparent 50%);
}

.mode-item.reading:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 15rpx rgba(255, 193, 7, 0.5);
}

.mode-item.writing {
  background: linear-gradient(135deg, #81C784 0%, #66BB6A 50%, #4CAF50 100%);
  box-shadow: 0 8rpx 25rpx rgba(76, 175, 80, 0.4);
}

.mode-item.writing::before {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.3) 0%, transparent 50%);
}

.mode-item.writing:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 15rpx rgba(76, 175, 80, 0.5);
}

.mode-badge {
  font-size: 28rpx;
  margin-right: 20rpx;
  animation: badgeBounce 1.5s ease-in-out infinite;
}

@keyframes badgeBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-5rpx); }
}

.mode-icon {
  font-size: 72rpx;
  margin-right: 25rpx;
  animation: iconWiggle 2s ease-in-out infinite;
}

@keyframes iconWiggle {
  0%, 100% { transform: rotate(-3deg); }
  50% { transform: rotate(3deg); }
}

.mode-name {
  flex: 1;
  font-size: 40rpx;
  font-weight: bold;
  color: #5D4037;
}

.mode-desc {
  font-size: 26rpx;
  color: #6D4C41;
  margin-right: 20rpx;
}

.mode-arrow {
  font-size: 36rpx;
  color: #5D4037;
  animation: arrowPulse 1s ease-in-out infinite;
}

@keyframes arrowPulse {
  0%, 100% { opacity: 0.6; transform: translateX(0); }
  50% { opacity: 1; transform: translateX(10rpx); }
}

.mode-divider {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  width: 100%;
}

.divider-line {
  flex: 1;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, #FFE082, transparent);
}

.divider-dot {
  margin: 0 15rpx;
  font-size: 24rpx;
  animation: dotBounce 2s ease-in-out infinite;
}

.divider-dot:last-child {
  animation-delay: 0.5s;
}

@keyframes dotBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

.options-section {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 32rpx;
  padding: 40rpx;
  margin-bottom: 35rpx;
  box-shadow: 0 20rpx 50rpx rgba(230, 81, 0, 0.2);
}

.back-btn {
  font-size: 34rpx;
  color: #FF7043;
  font-weight: bold;
  margin-bottom: 25rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  animation: backArrow 1.5s ease-in-out infinite;
}

.back-btn::before {
  content: '🏠';
  font-size: 32rpx;
}

@keyframes backArrow {
  0%, 100% { padding-left: 0; }
  50% { padding-left: 10rpx; }
}

.options-title {
  font-size: 38rpx;
  font-weight: bold;
  color: #E65100;
  margin-bottom: 20rpx;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 15rpx;
}

.options-subtitle {
  font-size: 28rpx;
  color: #8D6E63;
  text-align: center;
  margin-bottom: 35rpx;
}

.difficulty-options {
  display: flex;
  flex-direction: column;
  gap: 25rpx;
  margin-bottom: 45rpx;
}

.difficulty-item {
  display: flex;
  align-items: center;
  padding: 30rpx 35rpx;
  background: linear-gradient(135deg, #FFF8E1, #FFECB3);
  border-radius: 20rpx;
  transition: all 0.3s;
  border: 4rpx solid #FFE082;
  position: relative;
}

.difficulty-item.active {
  background: linear-gradient(135deg, #4FC3F7, #29B6F6);
  border-color: #0288D1;
  box-shadow: 0 10rpx 30rpx rgba(41, 182, 246, 0.4);
}

.difficulty-badge {
  font-size: 56rpx;
  margin-right: 25rpx;
  animation: badgeFloat 2s ease-in-out infinite;
}

@keyframes badgeFloat {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  25% { transform: translateY(-5rpx) rotate(5deg); }
  75% { transform: translateY(5rpx) rotate(-5deg); }
}

.difficulty-content {
  flex: 1;
}

.difficulty-star {
  font-size: 28rpx;
  margin-bottom: 5rpx;
}

.difficulty-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #5D4037;
}

.difficulty-item.active .difficulty-name {
  color: #ffffff;
}

.difficulty-check {
  font-size: 40rpx;
  color: #ffffff;
  font-weight: bold;
  animation: checkPop 0.5s ease-out;
}

@keyframes checkPop {
  0% { transform: scale(0); }
  50% { transform: scale(1.3); }
  100% { transform: scale(1); }
}

.method-options {
  display: flex;
  flex-direction: column;
  gap: 25rpx;
  margin-bottom: 45rpx;
}

.method-item {
  display: flex;
  align-items: center;
  padding: 30rpx 35rpx;
  background: linear-gradient(135deg, #FFECB3, #FFE082);
  border-radius: 20rpx;
  transition: all 0.3s;
  border: 4rpx solid #FFD54F;
}

.method-item.active {
  background: linear-gradient(135deg, #FFAB91, #FF8A65);
  border-color: #E64A19;
  box-shadow: 0 10rpx 30rpx rgba(230, 74, 25, 0.4);
}

.method-icon {
  font-size: 56rpx;
  margin-right: 25rpx;
}

.method-content {
  flex: 1;
}

.method-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #5D4037;
  margin-bottom: 8rpx;
}

.method-item.active .method-name {
  color: #ffffff;
}

.method-desc {
  font-size: 26rpx;
  color: #666;
}

.method-item.active .method-desc {
  color: rgba(255, 255, 255, 0.9);
}

.image-options {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 25rpx;
  margin-bottom: 45rpx;
}

.image-item {
  width: 180rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, #FCE4EC, #F8BBD9);
  border-radius: 20rpx;
  transition: all 0.3s;
  border: 4rpx solid #F48FB1;
}

.image-item.active {
  background: linear-gradient(135deg, #CE93D8, #BA68C8);
  border-color: #7B1FA2;
  box-shadow: 0 10rpx 30rpx rgba(123, 31, 162, 0.4);
  transform: scale(1.05);
}

.image-preview {
  width: 100%;
  height: 130rpx;
  border-radius: 16rpx;
  margin-bottom: 15rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.15);
}

.image-name {
  font-size: 26rpx;
  color: #5D4037;
  text-align: center;
  font-weight: 600;
}

.image-item.active .image-name {
  color: #ffffff;
}

.confirm-btn {
  text-align: center;
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 50%, #81C784 100%);
  color: #ffffff;
  padding: 30rpx;
  border-radius: 50rpx;
  font-size: 36rpx;
  font-weight: bold;
  box-shadow: 0 12rpx 35rpx rgba(76, 175, 80, 0.4);
  position: relative;
  overflow: hidden;
}

.confirm-btn::before {
  content: '🚀';
  margin-right: 10rpx;
}

.confirm-btn:active {
  transform: scale(0.97);
  box-shadow: 0 6rpx 20rpx rgba(76, 175, 80, 0.5);
}

.welcome-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  padding: 50rpx 40rpx;
  text-align: center;
  box-shadow: 0 15rpx 40rpx rgba(230, 81, 0, 0.15);
  position: relative;
}

.welcome-card::before {
  content: '🎒';
  position: absolute;
  top: -30rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 64rpx;
  animation: backpackFloat 3s ease-in-out infinite;
}

@keyframes backpackFloat {
  0%, 100% { transform: translateX(-50%) translateY(0) rotate(0deg); }
  25% { transform: translateX(-50%) translateY(-10rpx) rotate(5deg); }
  75% { transform: translateX(-50%) translateY(10rpx) rotate(-5deg); }
}

.welcome-icon {
  font-size: 96rpx;
  margin-bottom: 25rpx;
  animation: iconFloat 3s ease-in-out infinite;
}

.welcome-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #E65100;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 15rpx;
}

.welcome-title::before,
.welcome-title::after {
  content: '🎉';
}

.welcome-desc {
  font-size: 30rpx;
  color: #795548;
  line-height: 1.6;
}

@keyframes titleBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-15rpx); }
}

@keyframes starTwinkle {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(1.3); }
}

@keyframes sparkleFloat {
  0%, 100% { transform: translateY(0); opacity: 1; }
  50% { transform: translateY(-20rpx); opacity: 0.6; }
}

@keyframes iconFloat {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  25% { transform: translateY(-15rpx) rotate(8deg); }
  75% { transform: translateY(15rpx) rotate(-8deg); }
}
